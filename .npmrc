# Electron downloads its binary via a postinstall script. Newer npm
# strips project-config keys it doesn't recognise, so the old
# `electron_mirror=...` form is silently ignored — install.js never sees
# the mirror and quietly skips the download, then `npm run dev` fails
# with "Electron uninstall". Use the uppercase env-var form instead:
# install.js reads process.env directly.
ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/
ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/
